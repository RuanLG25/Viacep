@model ViaCep.Models.EnderecoViewModel

@{
    ViewData["Title"] = "Dados Confirmados";
}

<h2>Dados Confirmados</h2>
<p class="text-muted">Dados recebidos pelo servidor via Model Binding.</p>

<div class="card" style="max-width: 580px;">

    <div class="card-header"><strong>Dados Pessoais</strong></div>
    <ul class="list-group list-group-flush">
        <li class="list-group-item">
            <strong>Nome:</strong> @Model.NomeCompleto
        </li>
        <li class="list-group-item">
            <strong>CPF:</strong> @Model.Cpf
        </li>
        </ul>

    <div class="card-header mt-1"><strong>Endereço</strong></div>
    <ul class="list-group list-group-flush">
        <li class="list-group-item">
            <strong>CEP:</strong> @Model.Cep
        </li>
        <li class="list-group-item">
            <strong>Logradouro:</strong> @Model.Logradouro
        </li>
        <li class="list-group-item">
            <strong>Bairro:</strong> @Model.Bairro
        </li>
        <li class="list-group-item">
            <strong>Cidade / UF:</strong> @Model.Cidade — @Model.Uf
        </li>
    </ul>

</div>

<a asp-action="Index" class="btn btn-secondary mt-3">← Nova consulta</a>