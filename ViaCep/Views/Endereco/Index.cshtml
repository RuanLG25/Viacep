@model ViaCep.Models.EnderecoViewModel

@{
    ViewData["Title"] = "Consulta de CEP";
}

<h2>Preencha seus dados</h2>

<form asp-action="Index" method="post">

    <div class="mb-3">
        <label asp-for="NomeCompleto" class="form-label">Nome Completo</label>
        <input asp-for="NomeCompleto" class="form-control" required />
    </div>

    <div class="mb-3">
        <label asp-for="Cpf" class="form-label">CPF</label>
        <input asp-for="Cpf" class="form-control" required />
    </div>
    <div class="mb-3">
        <label asp-for="Cep" class="form-label">CEP</label>
        <div class="input-group">
            <input asp-for="Cep" class="form-control" id="campoCep"
                   maxlength="9" placeholder="00000-000" required />
            <button type="button" class="btn btn-outline-secondary"
                    id="btnBuscarCep">Buscar</button>
        </div>
        <small id="msgCep" class="text-danger"></small>
    </div>

    <hr />
    <h5>Endereço (preenchido automaticamente pelo jQuery)</h5>

    <div class="mb-3">
        <label asp-for="Logradouro" class="form-label">Logradouro</label>
        <input asp-for="Logradouro" class="form-control" id="campoLogradouro" readonly />
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Bairro" class="form-label">Bairro</label>
            <input asp-for="Bairro" class="form-control" id="campoBairro" readonly />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Cidade" class="form-label">Cidade</label>
            <input asp-for="Cidade" class="form-control" id="campoCidade" readonly />
        </div>
        <div class="col-md-2 mb-3">
            <label asp-for="Uf" class="form-label">UF</label>
            <input asp-for="Uf" class="form-control" id="campoUf" readonly />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Enviar</button>
</form>
@section Scripts {
<script>
$(document).ready(function () {

    function buscarCep(cep) {
        cep = cep.replace(/\D/g, '');

        if (cep.length !== 8) {
            $('#msgCep').text('CEP deve ter 8 dígitos.');
            return;
        }

        $('#msgCep').text('Buscando...');

        $.ajax({
             url: 'https://viacep.com.br/ws/' + cep + '/json/',
            type: 'GET',
            dataType: 'json',
            success: function (dados) {
                if (dados.erro) {
                    $('#msgCep').text('CEP não encontrado.');
                    limparCampos();
                } else {
                    $('#msgCep').text('');
                    $('#campoLogradouro').val(dados.logradouro);
                    $('#campoBairro').val(dados.bairro);
                    $('#campoCidade').val(dados.localidade);
                    $('#campoUf').val(dados.uf);
                }
            },
            error: function () {
                $('#msgCep').text('Erro ao consultar o CEP.');
                limparCampos();
            }
        });
         }

    function limparCampos() {
        $('#campoLogradouro, #campoBairro, #campoCidade, #campoUf').val('');
    }

    $('#btnBuscarCep').on('click', function () {
        buscarCep($('#campoCep').val());
    });

    $('#campoCep').on('blur', function () {
        if ($(this).val().length > 0) {
            buscarCep($(this).val());
        }
    });
});
</script>
}